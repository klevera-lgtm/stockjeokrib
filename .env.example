VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── 토스 콘솔 발급 ID (등록 후 값 입력 시 기능 활성화) ──
# 공유 리워드: 콘솔 > 공유 리워드 > 리워드 ID
VITE_VIRAL_MODULE_ID=

# 인앱 광고: 콘솔 > 인앱 광고 > 광고 그룹 ID (미입력 시 테스트 광고)
VITE_REWARDED_AD_GROUP_ID=
VITE_INTERSTITIAL_AD_GROUP_ID=

# 인앱 결제: 콘솔에 SKU를 coin_10 / coin_35 / coin_100 형식으로 등록
# (SKU에서 코인 개수를 자동 인식하므로 별도 설정 불필요)
